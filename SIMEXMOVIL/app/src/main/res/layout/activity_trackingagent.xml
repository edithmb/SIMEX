<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#E4E8ED"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTituloOrden"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            tools:text="Electrónica — ORD-2024-0035"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvBadgeEstado" />

        <TextView
            android:id="@+id/tvBadgeEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_etiqueta_verde"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            tools:text="En aduana"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTituloOrden"
            app:layout_constraintBottom_toBottomOf="@id/tvTituloOrden" />

        <TextView
            android:id="@+id/tvRutaPrincipal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            tools:text="Taiwán → Bogotá · Importación"
            android:textColor="#7A7A7A"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTituloOrden" />

        <LinearLayout
            android:id="@+id/layoutDatos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvRutaPrincipal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Origen"
                    android:textSize="12sp"
                    android:textColor="#A0A0A0"/>

                <TextView
                    android:id="@+id/tvOrigen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Kaohsiung"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destino"
                    android:textSize="12sp"
                    android:textColor="#A0A0A0"/>
                <TextView
                    android:id="@+id/tvDestino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Bogotá"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Llegada estimada"
                    android:textSize="12sp"
                    android:textColor="#A0A0A0"/>
                <TextView
                    android:id="@+id/tvEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="05 Jul 2025"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutDatos">

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#DDE2E8"
                app:layout_constraintStart_toStartOf="@id/punto1"
                app:layout_constraintEnd_toEndOf="@id/punto5"
                app:layout_constraintTop_toTopOf="@id/punto1"
                app:layout_constraintBottom_toBottomOf="@id/punto1" />

            <View
                android:id="@+id/lineaProgresoVerde"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/green"
                app:layout_constraintStart_toStartOf="@id/punto1"
                app:layout_constraintEnd_toStartOf="@id/punto4"
                app:layout_constraintTop_toTopOf="@id/punto1"
                app:layout_constraintBottom_toBottomOf="@id/punto1" />

            <View
                android:id="@+id/punto1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_punto_activo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/punto2"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/punto2"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_punto_activo"
                app:layout_constraintStart_toEndOf="@id/punto1"
                app:layout_constraintEnd_toStartOf="@id/punto3"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/punto3"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_punto_activo"
                app:layout_constraintStart_toEndOf="@id/punto2"
                app:layout_constraintEnd_toStartOf="@id/punto4"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/punto4"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_punto_activo"
                app:layout_constraintStart_toEndOf="@id/punto3"
                app:layout_constraintEnd_toStartOf="@id/punto5"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/punto1"/>
            <View
                android:id="@+id/punto5"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_punto_inactivo"
                app:layout_constraintStart_toEndOf="@id/punto4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recogida"
                android:textSize="10sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/punto1"
                app:layout_constraintStart_toStartOf="@id/punto1"
                app:layout_constraintEnd_toEndOf="@id/punto1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salida"
                android:textSize="10sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/punto2"
                app:layout_constraintStart_toStartOf="@id/punto2"
                app:layout_constraintEnd_toEndOf="@id/punto2"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En tránsito"
                android:textSize="10sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/punto3"
                app:layout_constraintStart_toStartOf="@id/punto3"
                app:layout_constraintEnd_toEndOf="@id/punto3"/>
            <TextView
                android:id="@+id/tvPasoActivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En aduana"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/punto4"
                app:layout_constraintStart_toStartOf="@id/punto4"
                app:layout_constraintEnd_toEndOf="@id/punto4"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entregado"
                android:textSize="10sp"
                android:textColor="#A0A0A0"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/punto5"
                app:layout_constraintStart_toStartOf="@id/punto5"
                app:layout_constraintEnd_toEndOf="@id/punto5"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/layoutInfoBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF4E5"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutTimeline"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvInfoTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Tienes que gestionar el despacho de aduana"
                android:textColor="#B26A00"
                android:textStyle="bold"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_campana"
                android:drawablePadding="8dp"/>

            <TextView
                android:id="@+id/tvInfoDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="32dp"
                tools:text="La mercancía está en el puerto de Bogotá. Contacta a tu agente de aduanas para completar los trámites de importación e impuestos."
                android:textColor="#555555"
                android:textSize="13sp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>