    origen: 'Shanghai',
    destino: 'Valencia',
    transport: 'ship',
    fechaDeseada: '20/04/2024',
    status: 'Enviada',
  },
  {
    ref: 'SOL-2024-131',
    tipoMercancia: 'Textiles',
    origen: 'Mumbai',
    destino: 'Barcelona',
    transport: 'ship',
    fechaDeseada: '15/05/2024',
    status: 'Aceptada',
  },
  {
    ref: 'SOL-2024-132',
    tipoMercancia: 'Maquinaria industrial',
    origen: 'Frankfurt',
    destino: 'Madrid',
    transport: 'truck',
    fechaDeseada: '01/04/2024',
    status: 'Pendiente',
  },
  {
    ref: 'SOL-2024-133',
    tipoMercancia: 'Alimentos perecederos',
    origen: 'Rotterdam',
